# ===== Postgres =====
POSTGRES_USER=music
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=music

# ===== Porta pública (Caddy) =====
# Tudo (front + /api) passa pelo Caddy nesta porta. O Cloudflare Tunnel aponta para cá.
PUBLIC_PORT=8080

# ===== Armazenamento dos .rar/.zip =====
RARS_HOST_PATH=./data/rars

# ===== App / mesma origem =====
# Vazio = front chama a API por caminho relativo /api (servido pelo Caddy). Deixe vazio.
NEXT_PUBLIC_API_URL=

# ===== Modo / segurança =====
# Produção: DEBUG=false (esconde /docs e exige JWT_SECRET forte).
DEBUG=false
# Produção atrás do Cloudflare (HTTPS): true. Dev local em HTTP: false.
COOKIE_SECURE=true

# ===== Autenticação / Admin / Quotas =====
# OBRIGATÓRIO em produção. Gere com:  openssl rand -hex 32
JWT_SECRET=
ADMIN_EMAIL=admin@seudominio.com
ADMIN_PASSWORD=troque-esta-senha-forte
DEFAULT_QUOTA_GB=5
ADMIN_QUOTA_GB=20
# WhatsApp do admin p/ upgrade de quota (DDI+DDD+número, só dígitos). Ex: 5585999999999.
ADMIN_WHATSAPP=
